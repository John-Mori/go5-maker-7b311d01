# OS / エディタが作る不要ファイル（MacBook等での作業用）
.DS_Store
Thumbs.db
*.swp

# wrangler ローカルキャッシュ（各worker配下）
.wrangler/
**/.wrangler/

# PCスクレイプ用のローカル設定（共有シークレットを含むためコミットしない）
scripts/scrape_config.json

# GAS自動反映のローカル設定（scriptId・デプロイID・adminSecret を含むためコミットしない）
.clasp.json
scripts/gas_deploy_config.json
# 販売数スクレイプの前回実行時刻（このPC専用のローカル状態）
scripts/sales_state.json
